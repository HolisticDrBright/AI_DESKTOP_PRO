# ─────────────────────────────────────────────────────────────────────────────
# AI Desktop Pro — environment
#
# Copy to `.env.local` and fill in as needed. The app runs fully in DEMO mode
# with NO env at all; the variables below only matter for the live backend path.
# ─────────────────────────────────────────────────────────────────────────────

# Data-source mode. Default (unset/false) = demo/mock, nothing is persisted.
# "true" (or "1") routes the wired vertical slice through the real backend.
NEXT_PUBLIC_USE_LIVE_API=false

# ── Live backend (server-only; NEVER prefixed NEXT_PUBLIC — must stay server-side)
# The desktop talks to the shared authenticated tRPC backend, never to Postgres
# directly (ADR 0002). The backend is the one place that holds Supabase keys and
# calls the SECURITY DEFINER RPCs (migration 0013) as the authenticated user.
TRPC_BASE_URL=http://localhost:3000/api/trpc

# The organization the desktop scopes queries to (from the practitioner session
# in production; provided here for the live-path proof).
CLINICAL_ORG_ID=

# Demo practitioner sign-in for the live path (until the real login UI ships).
# Identity only — used to obtain a real access token so the backend runs RLS as
# that user. Server-only. Do NOT commit real values.
CLINICAL_SUPABASE_URL=
CLINICAL_SUPABASE_ANON_KEY=
CLINICAL_DEMO_EMAIL=
CLINICAL_DEMO_PASSWORD=

# ── Dev-only identity overrides  ⚠️ LOCAL DEVELOPMENT ONLY — UNSAFE FOR PRODUCTION
# These pin an org/patient/practitioner before the login UI exists. They are NOT
# authentication: the backend still enforces RLS against the real session token.
# Never set these in a deployed environment.
NEXT_PUBLIC_DEV_ORG_ID=
NEXT_PUBLIC_DEV_PATIENT_ID=
NEXT_PUBLIC_DEV_PRACTITIONER_ID=
